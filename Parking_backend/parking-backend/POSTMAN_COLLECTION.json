{
  "info": {
    "_postman_id": "moofu-parking-api",
    "name": "MOOFU Parking Backend API",
    "description": "Complete REST API collection for MOOFU Parking Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePass123\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login with Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Request OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"+919876543210\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/otp/request",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "otp", "request"]
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"+919876543210\",\n  \"otp\": \"1234\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/otp/verify",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "otp", "verify"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/auth/me",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\",\n  \"email\": \"jane@example.com\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/profile",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Parking Spaces",
      "item": [
        {
          "name": "Create Parking Space",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mall Parking - Level 1\",\n  \"latitude\": 28.6139,\n  \"longitude\": 77.2090,\n  \"lenderId\": \"owner-uuid\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/parking-space",
              "host": ["{{BASE_URL}}"],
              "path": ["parking-space"]
            }
          }
        },
        {
          "name": "Get Availability",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/parking-space/{{PARKING_SPACE_ID}}/availability",
              "host": ["{{BASE_URL}}"],
              "path": ["parking-space", "{{PARKING_SPACE_ID}}", "availability"]
            }
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"parkingSpaceId\": \"parking-space-uuid\",\n  \"vehicleType\": \"FOUR_WHEELER\",\n  \"vehicleNumber\": \"DL01AB1234\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/booking",
              "host": ["{{BASE_URL}}"],
              "path": ["booking"]
            }
          }
        },
        {
          "name": "Get Booking by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/booking/{{BOOKING_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["booking", "{{BOOKING_ID}}"]
            }
          }
        },
        {
          "name": "Get User Bookings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/user/{{USER_ID}}/booking",
              "host": ["{{BASE_URL}}"],
              "path": ["user", "{{USER_ID}}", "booking"]
            }
          }
        },
        {
          "name": "Get Space Bookings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/parkingSpace/{{PARKING_SPACE_ID}}/booking",
              "host": ["{{BASE_URL}}"],
              "path": ["parkingSpace", "{{PARKING_SPACE_ID}}", "booking"]
            }
          }
        }
      ]
    },
    {
      "name": "Entry/Exit",
      "item": [
        {
          "name": "Record Entry",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"booking-uuid\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/parking-entry",
              "host": ["{{BASE_URL}}"],
              "path": ["parking-entry"]
            }
          }
        },
        {
          "name": "Record Exit",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"booking-uuid\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/parking-exit",
              "host": ["{{BASE_URL}}"],
              "path": ["parking-exit"]
            }
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{BASE_URL}}/health",
          "host": ["{{BASE_URL}}"],
          "path": ["health"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "TOKEN",
      "value": "",
      "type": "string"
    },
    {
      "key": "USER_ID",
      "value": "",
      "type": "string"
    },
    {
      "key": "PARKING_SPACE_ID",
      "value": "",
      "type": "string"
    },
    {
      "key": "BOOKING_ID",
      "value": "",
      "type": "string"
    }
  ]
}
