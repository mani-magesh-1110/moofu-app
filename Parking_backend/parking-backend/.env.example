# ====================
# SERVER CONFIGURATION
# ====================
PORT=5000
NODE_ENV=development

# ====================
# DATABASE CONFIGURATION (PostgreSQL)
# ====================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=moofu_parking

# ====================
# JWT CONFIGURATION
# ====================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars_strong
JWT_EXPIRY=7d

# ====================
# APPLICATION CONFIGURATION
# ====================
API_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ====================
# CORS CONFIGURATION
# ====================
# Allow multiple origins separated by comma
CORS_ORIGIN=http://localhost:3000,http://localhost:19000,http://192.168.1.100

# ====================
# LOGGING
# ====================
LOG_LEVEL=debug

# ====================
# OPTIONAL: Twilio Configuration (for SMS/WhatsApp notifications)
# ====================
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_WHATSAPP_NUMBER=+1234567890

# ====================
# OPTIONAL: Sentry Configuration (for error tracking)
# ====================
# SENTRY_DSN=your_sentry_dsn_url
